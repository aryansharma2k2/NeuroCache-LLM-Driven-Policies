Body lines: ['void InitReplacementState() {', '\tconfig = get_config_number ();', '\tswitch (config) {', '\t\tcase 1: case 2:', '\t\t\tnum_core = 1;', '\t\t\tllc_sets = 2048;', '\t\t\tbreak;', '\t\tcase 3: case 4:', '\t\t\tnum_core = 4;', '\t\t\tllc_sets = 8192;', '\t\t\tbreak;', '\t\tcase 5: case 6:', '\t\t\tnum_core = 1;', '\t\t\tllc_sets = 8192;', '\t\t\tbreak;', '\t\tdefault: assert (0);', '\t}', '\tprintf ("config %d, num_core %d, llc_sets %d\\n", config, num_core, llc_sets);', '', '\t// default parameters', '', '\tset_parameters ();', '', '\t// this variable helps put physical addresses back together', '', '\tif (llc_sets == 2048) {', '\t\tlognsets = 11;', '\t} else if (llc_sets == 8192) {', '\t\tlognsets = 13;', '\t} else assert (0);', '\tlognsets6 = lognsets + 6;', '', '\t// initialize replacement state', '', '\tif (num_core == 4) {', '', '\t\t// multi-core configurations use RRIP', '', '\t\trrpv = new unsigned char*[llc_sets];', '\t\tint rrpv_bits = 0;', '\t\tfor (unsigned int i=0; i<llc_sets; i++) {', '\t\t\trrpv[i] = new unsigned char[LLC_WAYS];', '\t\t\tmemset (rrpv[i], 3, LLC_WAYS);', '\t\t\trrpv_bits += 2 * LLC_WAYS;', '\t\t}', '\t\ttotal_bits += rrpv_bits;', '\t} else if (num_core == 1) {', '', '\t\t// single-core configurations use MDPP/PLRU', '', '\t\tint bits = 0;', '\t\tplru_bits = new bool*[llc_sets];', '\t\tfor (unsigned int i=0; i<llc_sets; i++) {', '\t\t\tplru_bits[i] = new bool[LLC_WAYS-1];', '\t\t\tmemset (plru_bits[0], 0, LLC_WAYS-1);', '\t\t\tbits += LLC_WAYS-1;', '\t\t}', '\t\ttotal_bits += bits;', '\t} else assert (0);', '', '\t// per-core arrays of recent PCs (we count the bits later when we know the max PC width)', '', '\taddresses = new unsigned int*[num_core];', '\tfor (unsigned int i=0; i<num_core; i++) {', '\t\taddresses[i] = new unsigned int[MAX_PATH_LENGTH];', '\t\tmemset (addresses[i], 0, sizeof (int) * MAX_PATH_LENGTH);', '\t}', '', '\t// initialize lastmiss feature', '', '\tlastmiss_bits = new bool[llc_sets];', '\tmemset (lastmiss_bits, 0, llc_sets);', '\ttotal_bits += llc_sets;', '', '\t// initialize sampler', '', '\tsamp = new sdbp_sampler (llc_sets, LLC_WAYS);', '', '\t// at this point, the specs are set; we can compute the sizes', '', '\tint trace_bits = 0;', '\tfor (int i=0; i<dan_predictor_tables; i++) {', '\t\tswitch (specs[i].type) {', '\t\tcase F_BIAS:', '\t\tcase F_BURST:', '\t\tcase F_LM:', '\t\tcase F_INS:', '\t\t\tif (specs[i].xorpc == 0 || specs[i].xorpc == 2) trace_bits += 1; else trace_bits += dan_predictor_index_bits;', '\t\t\tbreak;', '\t\tcase F_OFF:', '\t\t\tif (specs[i].xorpc == 0 || specs[i].xorpc == 2) trace_bits += (specs[i].end-specs[i].begin); ', '\t\t\telse trace_bits += dan_predictor_index_bits;', '\t\t\tbreak;', '\t\tdefault:', '\t\t\ttrace_bits += dan_predictor_index_bits;', '\t\t\tbreak;', '\t\t}', '\t}', '\tint sampler_set_bits = dan_sampler_assoc * (', '\t\t4 // lru stack position', '\t+\tdan_sampler_tag_bits', '\t+\ttrace_bits\t\t// bits for the trace stored in each sampler entry', '\t+ \t9 // confidence bits', '\t);', '', '\ttotal_bits += trace_bits;\t// global trace buffer', '', '', '\t// figure out how many bits we need to store the global array of PCs', '', '\tint max_end = 0;', '\tfor (int i=0; i<dan_predictor_tables; i++) {', '\t\tif (specs[i].type == F_PC) if (specs[i].end > max_end) max_end = specs[i].end;', '\t}', '\ttotal_bits += max_end * MAX_PATH_LENGTH * num_core;', '\t//int total_bits_allowed = 8 * 32768 * num_core;', '\t//int sampler_bits = total_bits_allowed - total_bits;', '\ttotal_bits += 10; // for psel', '\ttotal_bits += 512; // in case someone wants to be pedantic about something', '\ttotal_bits += dan_samplers * sampler_set_bits;', '}']
