Body lines: ['static void update_plru_mdpp (int set, int32_t wayID, bool hit, int *vector, uint32_t accessType, bool really = true, int conf = 0) {', '\tassert (!dan_use_rrip);', '\tassert (wayID < 16);', '\tbool P[LLC_WAYS-1];', '\tmemcpy (P, plru_bits[set], LLC_WAYS-1);', '\tunsigned int idx = 0;', '\tunsigned int x;', '\tbool wasodd = false;', '\tunsigned int newidx = 0;', '\tassert (vector);', '\tif (!hit) {', '\t\tif (conf >= plv[2][0]) newidx = plv[2][1];', '\t\telse if (conf >= plv[1][0]) newidx = plv[1][1];', '\t\telse if (conf >= plv[0][0]) newidx = plv[0][1];', '\t} else {', '\t\t// get the current plru index', '\t\t// build the index starting from a leaf and going to the root', '\t\tx = wayID + LLC_WAYS - 1;', '\t\tint i = 0;', '\t\twhile (x) {', '\t\t\twasodd = x & 1;', '\t\t\tx = (x - 1) >> 1;', '\t\t\t// FIXME: here we say 3 but it should be log2(assoc)-1', '\t\t\tif (P[x] == wasodd) SETBIT(idx,3-i);', '\t\t\ti++;', '\t\t}', '\t\tassert (i == 4);', '\t\tnewidx = vector[idx];', '\t}', '', '\t// set the new plru index for this block', '', '\twasodd = false;', '\tx = wayID + LLC_WAYS - 1;', '\tint i = 0;', '\tbool changed = false;', '\twhile (x) {', '\t\twasodd = x & 1;', '\t\tx = (x - 1) >> 1;', '\t\t// FIXME: here we say 3 but it should be log2(assoc)-1', '\t\tbool oldbit = P[x];', '\t\tP[x] = wasodd == GETBIT(newidx,3-i);', '\t\tif (P[x] != oldbit) changed = true;', '\t\ti++;', '\t}', '\twas_burst = !changed;', '\tassert (i == 4);', '\tif (conf > dan_promotion_threshold) really = false;', '', '\t// we might not "really" want to update state if we are just', '\t// calling this function to see if we had a cache burst', '', '\tif (really) memcpy (plru_bits[set], P, LLC_WAYS-1);', '}']
