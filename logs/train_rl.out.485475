dictor that this block has reached', '\t\t\t// this position', '\t\t\tpred->block_is_dead (tid, &blocks[way], blocks[way].trace_buffer, true, blocks[way].conf, blocks[way].lru_stack_position);', '\t\t}', '\t}', '\tblocks[i].lru_stack_position = 0;', '', '\tif (is_fill) {', '\t\t// fill the victim block', '', '\t\tblocks[i].tag = partial_tag;', '\t}', '', '\t// record the trace', '', '\tmake_trace (tid, pred, real_set, PC, tag, accessType, position == 0, is_fill, lastmiss_bits[real_set], paddr & 63);', '\tmemcpy (blocks[i].trace_buffer, trace_buffer, (MAX_PATH_LENGTH+1) * sizeof (unsigned int));', '', '\t// get the next prediction for this entry', '', '\tblocks[i].conf = pred->get_prediction (tid, -1);', '}']
