Body lines: ['static void make_trace (uint32_t tid, perceptron_predictor *pred, uint32_t setIndex, uint64_t PC, uint32_t tag, int accessType, bool burst, bool insertion, bool lastmiss, unsigned int offset) {', '\tfor (int i=0; i<dan_predictor_tables; i++) {', '\t\tfeature_spec *f = &specs[i];', '\t\tint begin_shift = f->begin;', '\t\tint end_mask = (1<<(f->end - begin_shift))-1; // TODO: make this a hash instead of a simple bit extract', '\t\tswitch (f->type) {', '\t\tcase F_PC:', '\t\t\tif (f->which == 0)', '\t\t\t\ttrace_buffer[i] = (PC >> begin_shift) & end_mask;', '\t\t\telse', '\t\t\t\ttrace_buffer[i] = (addresses[tid][f->which-1] >> begin_shift) & end_mask;', '\t\t\tbreak;', '\t\tcase F_TAG:', '\t\t\ttrace_buffer[i] = (((tag << lognsets6) | (setIndex << 6)) >> begin_shift) & end_mask;', '\t\t\tbreak;', '\t\tcase F_BIAS:', '\t\t\ttrace_buffer[i] = 0;', '\t\t\tbreak;', '\t\tcase F_BURST:', '\t\t\ttrace_buffer[i] = burst;', '\t\t\tbreak;', '\t\tcase F_INS:', '\t\t\ttrace_buffer[i] = insertion;', '\t\t\tbreak;', '\t\tcase F_LM:', '\t\t\ttrace_buffer[i] = lastmiss;', '\t\t\tbreak;', '\t\tcase F_OFF:', '\t\t\ttrace_buffer[i] = (offset >> begin_shift) & end_mask;', '\t\t\tbreak;', '\t\t}', '\t\tif (f->xorpc & 1) trace_buffer[i] ^= PC;', '\t\tif (f->xorpc & 2) trace_buffer[i] ^= 2 * (accessType == PREFETCH);', '\t}', '}']
